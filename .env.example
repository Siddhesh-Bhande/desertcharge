# DesertCharge environment template.
# Copy to .env and fill in real values. Never commit .env.
# All secret keys live on the backend only. The frontend gets non-secret URLs.

# --- Backend: third-party API keys (secret, server-side only) ---
OPENCHARGEMAP_API_KEY=
NREL_API_KEY=
OPENROUTESERVICE_API_KEY=
# Census ACS works without a key for low volume; add one to raise limits.
CENSUS_API_KEY=

# --- Backend: database (Supabase PostGIS connection string) ---
DATABASE_URL=postgresql://user:password@host:5432/postgres

# --- Backend: services and config ---
NOMINATIM_BASE_URL=https://nominatim.openstreetmap.org
# Comma-separated origins allowed by CORS (the web app and portfolio iframe host).
ALLOWED_ORIGINS=http://localhost:5173
# Per-IP rate limit for endpoints that call paid or rate-limited APIs.
RATE_LIMIT_PER_MINUTE=30

# --- Frontend (Vite): non-secret URLs only. Never put a key here. ---
VITE_API_BASE_URL=http://localhost:8000
VITE_BASEMAP_URL=/basemap.pmtiles
VITE_GRID_URL=/grid.json
